{
	"compilerOptions": {
		"target": "esnext",
		"useDefineForClassFields": true,
		"allowSyntheticDefaultImports": true,
		"composite": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"strict": true,
		"jsx": "preserve",
		"sourceMap": false,
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"lib": ["esnext", "dom"],
		"types": [
			"vite/client", 
			"node", 
			"vuetify"
		],
		"paths": {
			"@/*": ["./*"],
			"typings/*": ["./typings/*"]
		},
	},
	"include": [
		"./**/*.ts", 
		"./**/*.d.ts", 
		"./**/*.tsx", 
		"./**/*.vue",
		"./typings/**/*.d.ts",
		"../vite.config.ts"
	],
}

